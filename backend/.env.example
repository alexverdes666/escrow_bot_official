NODE_ENV=production
PORT=3000
BACKEND_URL=https://your-app.onrender.com

MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/escrow_bot

BOT_TOKEN=your-bot-token
BOT_USERNAME=your_bot_username
USE_WEBHOOK=true
WEBHOOK_DOMAIN=https://your-app.onrender.com
WEBHOOK_PATH=/api/bot/webhook

JWT_SECRET=generate-a-long-random-string-here-min-32-chars
JWT_EXPIRES_IN=7d

FRONTEND_URL=https://your-app.vercel.app

ADMIN_TELEGRAM_IDS=your_telegram_id

# Crypto Wallet Integration
CRYPTO_ENABLED=false
CRYPTO_NETWORK=testnet
CRYPTO_MNEMONIC=your-24-word-mnemonic-here
CRYPTO_FEE_PERCENT=2
CRYPTO_FEE_WALLET_ETH=0x_your_eth_fee_wallet
CRYPTO_FEE_WALLET_BTC=your_btc_fee_wallet
CRYPTO_FEE_WALLET_TRON=your_tron_fee_wallet
ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
TRON_API_URL=https://nile.trongrid.io
TRON_API_KEY=your_trongrid_api_key
USDT_TRC20_CONTRACT=
